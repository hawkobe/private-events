<h1> Events <%= @user.username.capitalize %> is hosting:</h1>

<% @user.created_events.each do |event| %>
  <h2><%= event.name %></h2>
  <p> <%= event.location %></p>
  <p> <%= event.date.to_formatted_s(:long) %></p>
<% end %>

<h4>Upcoming Events <%= @user.username %> is attending:</h4>

<% @user.attended_events.where("date > ?", Time.zone.now).each do |upcoming_event| %>
  <p><%= upcoming_event.name %></p>
<% end %>

<h4>Past Events <%= @user.username %> has attended:</h4>

<% @user.attended_events.where("date < ?", Time.zone.now).each do |past_event| %>
  <p><%= past_event.name %></p>
<% end %>